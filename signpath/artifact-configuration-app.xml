<?xml version="1.0" encoding="utf-8"?>
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <parameters>
    <parameter name="version" required="true" />
  </parameters>
  <zip-file>
    <pe-file path="SpaceLens.exe"
             product-name="SpaceLens"
             product-version="${version}"
             file-version="${version}.0"
             company-name="SpaceLens"
             original-filename="SpaceLens.dll">
      <authenticode-sign hash-algorithm="sha256"
                         description="SpaceLens"
                         description-url="https://github.com/Purxy8/SpaceLens" />
    </pe-file>
  </zip-file>
</artifact-configuration>
